@model ResetPasswordViewModel
@{
    ViewData["Title"] = "ResetPassword";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="main-agileinfo">
	<div class="agileits-top">
		<form asp-action="ResetPassword" asp-controller="Account" method="post">
			<input class="text" asp-for="NewPassword" placeholder="New Password" required="">
			<span asp-validation-for="NewPassword" class="text-danger"></span>
			<br />
			<input class="text" asp-for="ConfirmNewPassword" placeholder="Confirm New Password" required="">
			<span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>

			<input type="submit" value="RESET PASSWORD">
		</form>
	</div>
</div>

