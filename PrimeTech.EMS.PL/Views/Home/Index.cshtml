@{
    ViewData["Title"] = "Home Page";
}

<div class="px-4 py-5 my-5 text-center bg-light rounded-3">
    <h1 class="display-5 fw-bold">Welcome to Your Company Portal</h1>
    <div class="col-lg-6 mx-auto">
        <p class="lead mb-4">
            Manage your company's departments and employees efficiently. From here, you can view, add, edit, and delete records with ease.
        </p>
    </div>
</div>

<div class="container">
    <div class="row">

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-building me-2"></i> Departments</h5>
                    <p class="card-text">
                        Browse the list of all departments, add new ones, or update existing department information.
                    </p>
                    <div class="mt-auto">
                        <a asp-controller="Department" asp-action="Index" class="btn btn-primary">
                            <i class="fas fa-list-alt me-2"></i> View All Departments
                        </a>
                        <a asp-controller="Department" asp-action="Create" class="btn btn-success">
                            <i class="fas fa-plus me-2"></i> Add New Department
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-users me-2"></i> Employees</h5>
                    <p class="card-text">
                        Manage all employee records. You can view employee details, add new hires, or modify their data.
                    </p>
                    <div class="mt-auto">
                        <a asp-controller="Employee" asp-action="Index" class="btn btn-primary">
                            <i class="fas fa-list-alt me-2"></i> View All Employees
                        </a>
                        <a asp-controller="Employee" asp-action="Create" class="btn btn-success">
                            <i class="fas fa-plus me-2"></i> Add New Employee
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>