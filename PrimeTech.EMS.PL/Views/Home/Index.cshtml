@{
    ViewData["Title"] = "Home Page";
}



<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold text-primary">Welcome to Company Management System 🚀</h1>
        <p class="text-muted fs-5">Manage your departments and employees with ease and efficiency</p>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- Departments -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100 transition">
                <div class="mb-3">
                    <i class="bi bi-building fs-1 text-primary"></i>
                </div>
                <h4 class="fw-bold">Departments</h4>
                <p class="text-secondary">Add, view, and manage company departments</p>
                <a asp-controller="Department" asp-action="Index" class="btn btn-outline-primary">
                    Go to Departments
                </a>
            </div>
        </div>

        <!-- Employees -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100 transition">
                <div class="mb-3">
                    <i class="bi bi-people fs-1 text-success"></i>
                </div>
                <h4 class="fw-bold">Employees</h4>
                <p class="text-secondary">Manage employees, salaries, and performance</p>
                <a asp-controller="Employee" asp-action="Index" class="btn btn-outline-success">
                    Go to Employees
                </a>
            </div>
        </div>
    </div>

    <hr class="my-5" />

    <!-- Dark Mode Button -->
    <div class="text-center">
        <button id="themeToggleBtn" class="btn btn-dark px-4 py-2">Toggle Dark Mode 🌗</button>
    </div>
</div>

@section Scripts {
    <script>
        // Animate cards on hover
        $(".card").hover(
            function () {
                $(this).addClass("shadow-lg border-primary");
                $(this).css("transform", "scale(1.05)");
            },
            function () {
                $(this).removeClass("shadow-lg border-primary");
                $(this).css("transform", "scale(1)");
            }
        );

        // Fade-in animation for the whole page
        $(document).ready(function () {
            $(".container").hide().fadeIn(1000);
        });

        // Toggle dark mode
        $("#themeToggleBtn").click(function () {
            $("body").toggleClass("bg-dark text-light");
            $(".card").toggleClass("bg-secondary text-white");
            $(this).toggleClass("btn-light btn-dark");
            $(this).text(
                $("body").hasClass("bg-dark") ? "Switch to Light Mode ☀️" : "Toggle Dark Mode 🌗"
            );
        });
    </script>
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
}
