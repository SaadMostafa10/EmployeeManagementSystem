
@model IEnumerable<EmployeeToReturnDTO>
@{
    ViewData["Title"] = "Employees";
    ViewBag.Action = "Employees";
}

<h1>All Employees</h1>
<br />
<br />

<a asp-controller="Employee" asp-action="Create" class="btn btn-primary">Create New Employee</a>
<br />

<div class="m-2">
    <form asp-action="index" class="row offset-2" method="get">
        <div class="col-8">
            <input class="form-control" type="text" name="search" placeholder="Search Employee By Name" />
        </div>
        <div class="col-4">
            <input type="submit" class="btn btn-outline-success" value="Search" />

        </div>
    </form>

</div>

@if (Model.Count() > 0)
{
    <table class="mt-4 table table-striped table-hover">
        <thead class="text-center">
            <tr>
                <th>@Html.DisplayNameFor(E => E.Name)</th>
                <th>@Html.DisplayNameFor(E => E.EmployeeType)</th>
                <th>@Html.DisplayNameFor(E => E.Email)</th>
                <th>@Html.DisplayNameFor(E => E.Department)</th>
                <th>@Html.DisplayNameFor(E => E.Age)</th>
                <th>@Html.DisplayNameFor(E => E.Salary)</th>
                <th>@Html.DisplayNameFor(E => E.IsActive)</th>
                <th>@Html.DisplayNameFor(E => E.Gender)</th>

                <th>Details</th>
                <th>Update</th>
                <th>Delete</th>
            </tr>
        </thead>

        <tbody class="text-center">
            @foreach (var employee in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(X => employee.Name)</td>
                    <td>@Html.DisplayFor(X => employee.EmployeeType)</td>
                    <td>@Html.DisplayFor(X => employee.Email)</td>
                    <td>@Html.DisplayFor(X => employee.Department)</td>
                    <td>@Html.DisplayFor(X => employee.Age)</td>
                    <td>@Html.DisplayFor(X => employee.Salary)</td>
                    <td>
                        <i class="fa @(employee.IsActive ? "fa-solid fa-circle-check text-success" : "fa-times-circle text-danger")"></i>
                    </td>
                    <td>@Html.DisplayFor(X => employee.Gender)</td>


                    <partial name="_BottonsPartial" model="@employee.Id" />

                    <td>
                        <a asp-action="Delete" asp-route-id="@employee.Id" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Delete
                        </a> 

                        <!-- Button trigger modal -->
                        @*<button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                            <i class="fas fa-trash"></i> Delete
                        </button>*@
                    </td>


                </tr>



                <!-- Modal -->
                @*<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h1 class="modal-title fs-5" id="exampleModalLabel">Delete Employee</h1>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                Are You Sure You Want To Delete this Employee?
                            </div>
                            <div class="modal-footer">
                                <form asp-action="Delete" asp-route-id="@employee.Id" method="post">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-danger">Delete</button>
                                </form>


                            </div>
                        </div>
                    </div>
                </div>*@
            }
        </tbody>
    </table>
}

else
{
    <div class="mt-4 alert alert-info">
        <h4>There is No Employee :(</h4>
    </div>
}

