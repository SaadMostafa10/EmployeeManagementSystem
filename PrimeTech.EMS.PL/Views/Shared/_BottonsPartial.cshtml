@model int
@if (ViewBag.Action == "Departments")
{
    <td>
        <a asp-controller="Department" asp-action="Details" asp-route-id="@Model" class="btn btn-warning">
            <i class="fas fa-eye"></i> Details
        </a>
    </td>
}
else
{
    <td>
        <a asp-controller="Employee" asp-action="Details" asp-route-id="@Model" class="btn btn-warning">
            <i class="fas fa-eye"></i> Details
        </a>
    </td>
}

<td>
    <a asp-action="Edit" asp-route-id="@Model" class="btn btn-success">
        <i class="fas fa-edit"></i> Update
    </a>
</td>
